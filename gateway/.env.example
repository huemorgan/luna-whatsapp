# Copy to .env for local dev. On Render, set these as env vars instead.

# Protects the /qr page and the /accounts admin API. Generate: openssl rand -hex 16
GATEWAY_ADMIN_KEY=

# Postgres. Local example below; on Render this comes from the managed DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luna_wa

# Auth root (persistent disk on Render). Each account keeps its Baileys
# session in <WA_AUTH_DIR>/<account_id>/. Local dev default:
WA_AUTH_DIR=./wa-auth

# ── Legacy single-account seed (003 multi-Luna) ────────────────────────────
# Accounts now live in the whatsapp_accounts registry (managed via the
# /accounts admin API). These two only seed the `default` account on first
# boot — a fresh multi-tenant deploy can leave them empty.
# MUST match LUNA_WHATSAPP_SHARED_SECRET on the Luna side. openssl rand -hex 32
WA_SHARED_SECRET=
# e.g. https://your-luna-host/api/p/plugin-whatsapp/inbound
LUNA_INBOUND_URL=

# Optional tuning
PORT=10000
GATEWAY_ID=gw-1
WA_SEND_DAILY_CAP=300
WA_LOG_LEVEL=warn
# Dev/test ONLY: accept sends with no linked number (cap+capture, no socket).
# Used by the dojo suite. Never set in production.
#WA_DRY_SEND=1
