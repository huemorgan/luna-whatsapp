# Copy to .env for local dev. On Render, set these as env vars instead.

# HMAC shared secret between the gateway and the Luna plugin. MUST match
# LUNA_WHATSAPP_SHARED_SECRET on the Luna side. Generate: openssl rand -hex 32
WA_SHARED_SECRET=

# Protects the /qr linking page. Generate: openssl rand -hex 16
GATEWAY_ADMIN_KEY=

# Where inbound WhatsApp events are POSTed (the Luna plugin route).
# Local Luna via a tunnel, e.g. https://your-tunnel.trycloudflare.com/api/p/plugin-whatsapp/inbound
LUNA_INBOUND_URL=

# Postgres. Local example below; on Render this comes from the managed DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/luna_wa

# Where Baileys stores auth (persistent disk on Render). Local dev default:
WA_AUTH_DIR=./wa-auth

# Optional tuning
PORT=10000
WA_ACCOUNT=default
WA_SEND_DAILY_CAP=300
WA_LOG_LEVEL=warn
